      "id": "f011b6fd-2d79-42e9-88b8-73e23b5f96bc",
      "name": "Download PDF",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-160, 288]
    },
    {
      "parameters": {
        "jsCode": "// Get binary PDF data from Download node\nconst binaryData = $input.first().binary?.data;\n\nif (!binaryData) {\n  throw new Error('No binary data received from PDF download node');\n}\n\nconst base64String = binaryData.data;\nconst mimeType     = binaryData.mimeType   || 'application/pdf';\nconst fileName     = binaryData.fileName   || 'purchase_order.pdf';\nconst base64Uri    = `data:${mimeType};base64,${base64String}`;\n\n// Get captions from Format node (per-founder unique approval links)\nconst fmt = $('Format Approval Message').first().json;\n\nconst dhruvPayload = JSON.stringify({\n  to_number:   '917860650640',\n  type:        'media',\n  message:     base64Uri,\n  text:        fmt.dhruv_caption,\n  filename:    fileName,\n  skip_filter: false\n});\n\nconst bhaskarPayload = JSON.stringify({\n  to_number:   '919958131069',\n  type:        'media',\n  message:     base64Uri,\n  text:        fmt.bhaskar_caption,\n  filename:    fileName,\n  skip_filter: false\n});\n\nreturn [{\n  json: {\n    ...fmt,\n    pdf_base64:      base64String,\n    pdf_mime_type:   mimeType,\n    pdf_file_name:   fileName,\n    dhruv_payload:   dhruvPayload,\n    bhaskar_payload: bhaskarPayload,\n  }\n}];"
      },
