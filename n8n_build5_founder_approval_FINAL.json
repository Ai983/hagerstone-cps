    {
      "parameters": {
        "jsCode": "const formatINR = (amount) => {\n  return new Intl.NumberFormat('en-IN', {\n    style: 'currency',\n    currency: 'INR',\n    minimumFractionDigits: 0,\n    maximumFractionDigits: 0,\n  }).format(amount);\n};\n\nconst raw = $input.first().json;\nconst body = raw.body || raw;\n\nconst grandTotal = parseFloat(body.grand_total || 0);\nconst totalValue = parseFloat(body.total_value  || 0);\nconst gstAmount  = parseFloat(body.gst_amount   || 0);\n\nconst poDate = body.delivery_date\n  ? new Date(body.delivery_date).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' })\n  : 'Not specified';\n\nconst buildCaption = (approvalLink) =>\n  '\\uD83C\\uDFD7\\uFE0F *HAGERSTONE \\u2014 PO APPROVAL REQUIRED*\\n\\n' +\n  '\\uD83D\\uDCCB *PO No:* '             + body.po_number     + '\\n' +\n  '\\uD83C\\uDFE2 *Supplier:* '          + (body.supplier_name || 'N/A') + '\\n' +\n  '\\uD83D\\uDCC5 *Delivery Date:* '     + poDate             + '\\n' +\n  '\\uD83D\\uDCB0 *Value (excl GST):* '  + formatINR(totalValue) + '\\n' +\n  '\\uD83E\\uDDFE *GST:* '               + formatINR(gstAmount)  + '\\n' +\n  '\\uD83D\\uDCB5 *Grand Total:* *'      + formatINR(grandTotal) + '*' +\n  (body.payment_terms ? '\\n\\uD83D\\uDCB3 *Payment:* ' + body.payment_terms : '') +\n  '\\n\\n\\u2705 *Approve / Reject PO:*\\n' + approvalLink +\n  '\\n\\n_System PO#: ' + body.po_number + '_';\n\nreturn [{\n  json: {\n    po_id:                 body.po_id,\n    po_number:             body.po_number,\n    supplier_name:         body.supplier_name,\n    total_value:           totalValue,\n    gst_amount:            gstAmount,\n    grand_total:           grandTotal,\n    payment_terms:         body.payment_terms,\n    po_pdf_url:            body.po_pdf_url || '',\n    grand_total_formatted: formatINR(grandTotal),\n    dhruv_approval_link:   body.dhruv_approval_link   || '',\n    bhaskar_approval_link: body.bhaskar_approval_link || '',\n    dhruv_caption:   buildCaption(body.dhruv_approval_link   || ''),\n    bhaskar_caption: buildCaption(body.bhaskar_approval_link || ''),\n  }\n}];"
      },
      "id": "4506e0b0-d812-42f2-846d-5e957571cbc1",
